---
import { Icon } from "astro-icon/components";
import {
  Card,
  CardHeader,
  CardTitle,
  CardDescription,
  CardContent,
} from "./ui/card";
import { Button } from "./ui/button";
import { Badge } from "./ui/badge";
import { Link } from "./ui/link";

interface Props {
  title: string;
  description: string;
  techStack: string[];
  status: string;
  gallery?: {
    image: string;
    alt: string;
    caption: string;
  }[];
  link?: string;
  github?: string;
}

const {
  title,
  description,
  techStack,
  gallery = [],
  link = "#",
  github = "#",
} = Astro.props as Props;

const isInternalLink = link.startsWith("/");
const carouselId = title
  .toLowerCase()
  .replace(/[^a-z0-9]+/g, "-")
  .replace(/(^-|-$)/g, "");
const galleryItems = gallery.length
  ? gallery
  : [
      {
        image: "/projects/gallery-1.svg",
        alt: `Vista previa de ${title}`,
        caption: "Vista previa del proyecto.",
      },
    ];
---

<Card>
  <div
    data-project-carousel={carouselId}
    class="relative aspect-16/10 overflow-hidden"
  >
    {
      galleryItems.map((item, index) => (
        <figure
          class:list={[
            "absolute inset-0 h-full w-full transition-opacity duration-300",
            index === 0 ? "opacity-100" : "pointer-events-none opacity-0",
          ]}
          data-carousel-image
          data-slide={index}
        >
          <img
            src={item.image}
            alt={item.alt}
            loading="lazy"
            class="h-full w-full object-cover"
          />
        </figure>
      ))
    }

    <div
      class="pointer-events-none absolute inset-0 bg-linear-to-t from-black/65 via-black/20 to-transparent"
    >
    </div>

    <div
      class="pointer-events-auto absolute right-3 bottom-3 z-20 flex items-center gap-1.5"
    >
      <Button
        type="button"
        variant="secondary"
        size="icon-xs"
        aria-label="Imagen anterior"
      >
        <Icon
          name="arrow-right"
          class="h-4 w-4 -scale-x-100"
          aria-hidden="true"
        />
        <span class="sr-only">Imagen anterior</span>
      </Button>

      <Button
        type="button"
        variant="secondary"
        size="icon-xs"
        aria-label="Imagen siguiente"
      >
        <Icon name="arrow-right" class="h-4 w-4" aria-hidden="true" />
        <span class="sr-only">Imagen siguiente</span>
      </Button>
    </div>

    <div
      class="pointer-events-auto absolute right-0 bottom-3 left-1/2 z-20 flex w-max -translate-x-1/2 justify-center gap-1.5"
    >
      {
        galleryItems.map((item, index) => (
          <button
            type="button"
            data-carousel-dot
            data-slide={index}
            aria-label={`Ir a la imagen ${index + 1}: ${item.caption}`}
            class:list={[
              "border-border-subtle h-2.5 w-2.5 rounded-full border transition-all",
              index === 0
                ? "bg-accent-glow scale-110"
                : "bg-bg-card/65 hover:bg-bg-card",
            ]}
          />
        ))
      }
    </div>
  </div>

  <CardHeader>
    <CardTitle>{title}</CardTitle>
    <CardDescription>{description}</CardDescription>
  </CardHeader>

  <CardContent className="z-10 pt-4">
    <ul class="mb-5 flex flex-wrap gap-2 md:mb-6">
      {
        techStack.map((tech) => (
          <li>
            <Badge variant="tag">{tech}</Badge>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-4 text-sm">
      <Link
        href={link}
        variant="link"
        target={isInternalLink ? undefined : "_blank"}
        rel={isInternalLink ? undefined : "noreferrer noopener"}
      >
        <Icon name="external-link" aria-hidden="true" />
        Ver proyecto
      </Link>
      <Link
        href={github}
        variant="link"
        className="text-tx-secondary hover:text-tx-main"
        target="_blank"
        rel="noreferrer noopener"
      >
        <Icon name="github" aria-hidden="true" />
        Repositorio
      </Link>
    </div>
  </CardContent>
</Card>
