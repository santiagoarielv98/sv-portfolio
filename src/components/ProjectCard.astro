---
import { Icon } from 'astro-icon/components'

interface Props {
	title: string;
	description: string;
	techStack: string[];
	status: string;
	link?: string;
	github?: string;
}

const { title, description, techStack, status, link = '#', github = '#' } = Astro.props as Props;

const statusClass = status.toLowerCase().includes('planeado')
	? 'bg-state-warning/15 text-state-warning border-state-warning/30'
	: 'bg-state-success/15 text-state-success border-state-success/30';
---

<article class="card group card-pad">
	<div class="card-content">
		<div class="mb-3 flex items-start justify-between gap-3 md:mb-4">
			<div class="flex h-11 w-11 items-center justify-center rounded-lg border border-border-subtle bg-bg-main text-accent-glow shadow-glass">
				<Icon name="folder-code" class="h-5 w-5" aria-hidden="true" />
			</div>
			<span class:list={['rounded-full border px-3 py-1 font-mono text-xs', statusClass]}>{status}</span>
		</div>

		<h3 class="mb-2 text-xl font-bold text-tx-main transition-colors duration-300 group-hover:text-accent-glow">{title}</h3>
		<p class="mb-4 text-sm leading-relaxed text-tx-secondary md:mb-5">{description}</p>

		<ul class="mb-5 flex flex-wrap gap-2 md:mb-6">
			{techStack.map((tech) => (
				<li class="rounded-lg border border-border-subtle bg-bg-hover px-2.5 py-1 font-mono text-xs text-tx-secondary transition-all duration-300 group-hover:border-border-strong group-hover:text-tx-main">{tech}</li>
			))}
		</ul>

		<div class="flex items-center gap-4 text-sm">
			<a href={link} class="inline-flex items-center gap-1 rounded-sm text-accent-glow transition-all duration-300 hover:text-accent-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-primary/50 focus-visible:ring-offset-2 focus-visible:ring-offset-bg-card" target="_blank" rel="noreferrer noopener">
				<Icon name="external-link" class="h-3.5 w-3.5 transition-transform duration-300" aria-hidden="true" />
				Ver proyecto
			</a>
			<a href={github} class="inline-flex items-center gap-1 text-tx-secondary transition-all duration-300 hover:text-tx-main focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-primary/50 focus-visible:ring-offset-2 focus-visible:ring-offset-bg-card rounded-sm" target="_blank" rel="noreferrer noopener">
				<Icon name="github" class="h-3.5 w-3.5 transition-transform duration-300" aria-hidden="true" />
				Repositorio
			</a>
		</div>
	</div>
</article>
