---
import { Icon } from "astro-icon/components";
import { formatPeriod } from "../../utils/date";
import {
  Card,
  CardHeader,
  CardTitle,
  CardDescription,
  CardContent,
} from "../ui/card";
import { Badge } from "../ui/badge";

interface ExperienceItem {
  company: string;
  role: string;
  location: string;
  startDate: string;
  endDate: string;
  image: string;
  highlights: string[];
}

interface Props {
  experience: ExperienceItem[];
}

const { experience } = Astro.props as Props;
---

<section>
  <h2 class="mb-4 text-2xl font-semibold md:mb-6">Experiencia</h2>
  <div class="space-y-3 sm:space-y-4 md:space-y-5">
    {
      experience.map((job) => (
        <Card>
          <CardHeader className="pb-0">
            <div class="flex items-start justify-between gap-3">
              <div class="border-border-subtle bg-bg-main shadow-glass flex h-11 w-11 items-center justify-center rounded-lg border">
                <img
                  src={job.image}
                  alt={job.company}
                  class="h-8 w-8 rounded object-cover"
                />
              </div>
              <Badge variant="outline" size="md">
                {formatPeriod(job.startDate, job.endDate)}
              </Badge>
            </div>
            <CardTitle className="group-hover:text-accent-glow mt-4 text-xl transition-colors duration-300">
              {job.role} · {job.company}
            </CardTitle>
            <CardDescription className="mt-2 inline-flex items-center gap-1.5">
              <Icon name="map-pin" class="h-3.5 w-3.5" aria-hidden="true" />
              {job.location}
            </CardDescription>
          </CardHeader>
          <CardContent className="pt-3 md:pt-4">
            <ul class="text-tx-secondary space-y-2 text-sm">
              {job.highlights.map((line) => (
                <li class="hover:text-tx-main flex gap-2 transition-colors duration-300">
                  <Icon
                    name="circle-check"
                    class="text-accent-primary mt-0.5 h-4 w-4 shrink-0"
                    aria-hidden="true"
                  />
                  <span>{line}</span>
                </li>
              ))}
            </ul>
          </CardContent>
        </Card>
      ))
    }
  </div>
</section>
