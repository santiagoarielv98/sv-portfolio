---
import { Icon } from "astro-icon/components";

interface Props {
  email: string;
}

const { email } = Astro.props as Props;
---

<footer
  class="border-border-subtle text-tx-secondary border-t pt-6 text-sm md:pt-8"
>
  <p class="inline-flex items-center gap-2">
    <Icon name="mail" class="text-accent-glow h-4 w-4" aria-hidden="true" />
    Contacto:
    <a
      class="text-accent-glow hover:text-accent-primary focus-visible:ring-accent-primary/50 focus-visible:ring-offset-bg-main transition-all duration-300 hover:underline focus-visible:rounded-sm focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none"
      href={`mailto:${email}`}>{email}</a
    >
  </p>
</footer>
