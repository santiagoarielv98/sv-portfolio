---
import { Icon } from 'astro-icon/components';

interface Props {
	email: string;
}

const { email } = Astro.props as Props;
---

<footer class="border-t border-border-subtle pt-8 text-sm text-tx-secondary">
	<p class="inline-flex items-center gap-2">
		<Icon name="mail" class="h-4 w-4 text-accent-glow" aria-hidden="true" />
		Contacto:
		<a class="text-accent-glow transition-colors hover:text-accent-primary" href={`mailto:${email}`}>{email}</a>
	</p>
</footer>
