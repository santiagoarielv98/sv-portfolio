---
import { Icon } from "astro-icon/components";
import ProjectCard from "../ProjectCard.astro";

interface ProjectItem {
  title: string;
  description: string;
  techStack: string[];
  status: string;
  gallery: {
    image: string;
    alt: string;
    caption: string;
  }[];
  link?: string;
  github?: string;
}

interface Props {
  projects: ProjectItem[];
}

const { projects } = Astro.props as Props;
---

<section>
  <div class="mb-4 flex items-center justify-between gap-3 md:mb-6">
    <h2 class="inline-flex items-center gap-2 text-2xl font-semibold">
      <Icon
        name="folder-open"
        class="text-accent-glow h-5 w-5 transition-transform duration-300 hover:rotate-3"
        aria-hidden="true"
      />
      Proyectos
    </h2>
    <a
      href="/proyectos"
      class="text-accent-glow hover:text-accent-primary focus-visible:ring-accent-primary/50 focus-visible:ring-offset-bg-main inline-flex items-center gap-1 rounded-sm text-sm transition-colors focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none"
    >
      Ver todos
      <Icon name="external-link" class="h-4 w-4" aria-hidden="true" />
    </a>
  </div>
  <div class="grid gap-3 sm:gap-4 md:grid-cols-2 md:gap-5 xl:grid-cols-3">
    {projects.map((project) => <ProjectCard {...project} />)}
  </div>
</section>
