---
import { Icon } from 'astro-icon/components';
import ProjectCard from '../ProjectCard.astro';

interface ProjectItem {
	title: string;
	description: string;
	techStack: string[];
	status: string;
	link?: string;
	github?: string;
}

interface Props {
	projects: ProjectItem[];
}

const { projects } = Astro.props as Props;
---

<section>
	<h2 class="mb-4 inline-flex items-center gap-2 text-2xl font-semibold md:mb-6">
		<Icon name="folder-open" class="h-5 w-5 text-accent-glow transition-transform duration-300 hover:rotate-3" aria-hidden="true" />
		Proyectos
	</h2>
	<div class="grid gap-3 sm:gap-4 md:grid-cols-2 md:gap-5 xl:grid-cols-3">
		{projects.map((project) => (
			<ProjectCard {...project} />
		))}
	</div>
</section>
