---
import { Icon } from 'astro-icon/components';
import PrimaryButton from '../PrimaryButton.astro';
import SocialIcon from '../SocialIcon.astro';

interface SocialLink {
	platform: string;
	url: string;
	icon: string;
}

interface Personal {
	name: string;
	role: string;
	location: string;
	availability: string;
	social: SocialLink[];
}

interface Props {
	personal: Personal;
	about: string;
}

const { personal, about } = Astro.props as Props;
---

<header class="border-b border-border-subtle pb-10">
	<div class="mb-6 inline-flex items-center gap-2 rounded-full border border-accent-primary/20 bg-accent-primary/10 px-3 py-1 font-mono text-xs font-medium text-accent-glow">
		<Icon name="sparkles" class="h-3.5 w-3.5" aria-hidden="true" />
		{personal.availability}
	</div>
	<h1 class="mb-4 max-w-4xl text-4xl font-bold leading-tight md:text-5xl">{personal.name}</h1>

	<div class="mb-6 flex flex-wrap items-center gap-x-5 gap-y-2 text-tx-secondary">
		<p class="inline-flex items-center gap-2 text-lg">
			<Icon name="briefcase" class="h-4 w-4 text-accent-glow" aria-hidden="true" />
			{personal.role}
		</p>
		<p class="inline-flex items-center gap-2 text-sm md:text-base">
			<Icon name="map-pin" class="h-4 w-4 text-accent-secondary" aria-hidden="true" />
			{personal.location}
		</p>
	</div>

	<p class="max-w-3xl text-base leading-relaxed text-tx-secondary">{about}</p>

	<div class="mt-8 flex flex-wrap gap-4">
		{personal.social.map((item) => (
			<PrimaryButton href={item.url} ariaLabel={`Abrir ${item.platform}`} target="_blank" rel="noreferrer noopener">
				<SocialIcon platform={item.icon ?? item.platform} class="h-4 w-4" />
				<span>{item.platform}</span>
			</PrimaryButton>
		))}
	</div>
</header>
