---
import { Icon } from 'astro-icon/components';
import PrimaryButton from '../PrimaryButton.astro';
import SocialIcon from '../SocialIcon.astro';

interface SocialLink {
	platform: string;
	url: string;
	icon: string;
}

interface Personal {
	name: string;
	role: string;
	location: string;
	availability: string;
	social: SocialLink[];
}

interface Props {
	personal: Personal;
	about: string;
}

const { personal, about } = Astro.props as Props;
---

<header class="border-b border-border-subtle pb-8 md:pb-10">
	<div class="mb-4 inline-flex items-center gap-2 rounded-full border border-accent-primary/20 bg-accent-primary/10 px-3 py-1 font-mono text-xs font-medium text-accent-glow transition-all duration-300 hover:border-accent-primary/35 hover:bg-accent-primary/15 md:mb-6">
		<Icon name="sparkles" class="h-3.5 w-3.5 transition-transform duration-300 hover:rotate-12" aria-hidden="true" />
		{personal.availability}
	</div>
	<h1 class="mb-3 max-w-4xl text-3xl font-bold leading-tight sm:text-4xl md:mb-4 md:text-5xl">{personal.name}</h1>

	<div class="mb-5 flex flex-wrap items-center gap-x-4 gap-y-2 text-tx-secondary md:mb-6 md:gap-x-5">
		<p class="inline-flex items-center gap-2 text-lg">
			<Icon name="briefcase" class="h-4 w-4 text-accent-glow" aria-hidden="true" />
			{personal.role}
		</p>
		<p class="inline-flex items-center gap-2 text-sm md:text-base">
			<Icon name="map-pin" class="h-4 w-4 text-accent-secondary" aria-hidden="true" />
			{personal.location}
		</p>
	</div>

	<p class="max-w-3xl text-base leading-relaxed text-tx-secondary transition-colors duration-300 hover:text-tx-main">{about}</p>

	<div class="mt-6 flex flex-wrap gap-3 md:mt-8 md:gap-4">
		{personal.social.map((item) => (
			<PrimaryButton href={item.url} ariaLabel={`Abrir ${item.platform}`} target="_blank" rel="noreferrer noopener">
				<SocialIcon platform={item.icon ?? item.platform} class="h-4 w-4" />
				<span>{item.platform}</span>
			</PrimaryButton>
		))}
	</div>
</header>
