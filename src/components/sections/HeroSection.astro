---
import { Icon } from "astro-icon/components";
import PrimaryButton from "../PrimaryButton.astro";
import SocialIcon from "../SocialIcon.astro";

interface SocialLink {
  platform: string;
  url: string;
  icon: string;
}

interface Personal {
  name: string;
  role: string;
  location: string;
  availability: string;
  social: SocialLink[];
}

interface Props {
  personal: Personal;
  about: string;
}

const { personal, about } = Astro.props as Props;
---

<header class="border-border-subtle border-b pb-8 md:pb-10">
  <div
    class="border-accent-primary/20 bg-accent-primary/10 text-accent-glow hover:border-accent-primary/35 hover:bg-accent-primary/15 mb-4 inline-flex items-center gap-2 rounded-full border px-3 py-1 font-mono text-xs font-medium transition-all duration-300 md:mb-6"
  >
    <Icon
      name="sparkles"
      class="h-3.5 w-3.5 transition-transform duration-300 hover:rotate-12"
      aria-hidden="true"
    />
    {personal.availability}
  </div>
  <h1
    class="mb-3 max-w-4xl text-3xl leading-tight font-bold sm:text-4xl md:mb-4 md:text-5xl"
  >
    {personal.name}
  </h1>

  <div
    class="text-tx-secondary mb-5 flex flex-wrap items-center gap-x-4 gap-y-2 md:mb-6 md:gap-x-5"
  >
    <p class="inline-flex items-center gap-2 text-lg">
      <Icon
        name="briefcase"
        class="text-accent-glow h-4 w-4"
        aria-hidden="true"
      />
      {personal.role}
    </p>
    <p class="inline-flex items-center gap-2 text-sm md:text-base">
      <Icon
        name="map-pin"
        class="text-accent-secondary h-4 w-4"
        aria-hidden="true"
      />
      {personal.location}
    </p>
  </div>

  <p
    class="text-tx-secondary hover:text-tx-main max-w-3xl text-base leading-relaxed transition-colors duration-300"
  >
    {about}
  </p>

  <div class="mt-6 flex flex-wrap gap-3 md:mt-8 md:gap-4">
    {
      personal.social.map((item) => (
        <PrimaryButton
          href={item.url}
          ariaLabel={`Abrir ${item.platform}`}
          target="_blank"
          rel="noreferrer noopener"
        >
          <SocialIcon platform={item.icon ?? item.platform} class="h-4 w-4" />
          <span>{item.platform}</span>
        </PrimaryButton>
      ))
    }
  </div>
</header>
