---
import { Icon } from "astro-icon/components";
import { formatPeriod } from "../../utils/date";
import {
  Card,
  CardHeader,
  CardTitle,
  CardDescription,
  CardContent,
} from "../ui/card";
import { Badge } from "../ui/badge";

interface EducationItem {
  institution: string;
  degree: string;
  startDate: string;
  endDate: string;
  location: string;
}

interface Props {
  education: EducationItem[];
}

const { education } = Astro.props as Props;
---

<section>
  <h2 class="mb-4 text-2xl font-semibold md:mb-6">Educación</h2>
  <div class="space-y-3 sm:space-y-4 md:space-y-5">
    {
      education.map((item) => (
        <Card className="group">
          <CardHeader className="pb-0">
            <div class="flex items-start justify-between gap-3">
              <div class="border-border-subtle bg-bg-main text-accent-secondary shadow-glass flex h-11 w-11 items-center justify-center rounded-lg border">
                <Icon name="school" class="h-5 w-5" aria-hidden="true" />
              </div>
              <Badge variant="outline" size="md">
                {formatPeriod(item.startDate, item.endDate)}
              </Badge>
            </div>
            <CardTitle>{item.degree}</CardTitle>
            <CardDescription className="mt-2 inline-flex items-center gap-1.5">
              <Icon name="map-pin" class="h-3.5 w-3.5" aria-hidden="true" />
              <span class="flex-1">
                {item.institution} · {item.location}
              </span>
            </CardDescription>
          </CardHeader>
          <CardContent className="pt-3 md:pt-4">
            <p class="text-tx-secondary text-sm">
              Formación académica orientada a desarrollo de software y
              arquitectura de sistemas.
            </p>
          </CardContent>
        </Card>
      ))
    }
  </div>
</section>
