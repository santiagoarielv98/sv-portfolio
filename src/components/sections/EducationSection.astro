---
import { Icon } from 'astro-icon/components';
import { formatPeriod } from '../../utils/date';

interface EducationItem {
	institution: string;
	degree: string;
	startDate: string;
	endDate: string;
	location: string;
}

interface Props {
	education: EducationItem[];
}

const { education } = Astro.props as Props;
---

<section class="card card-pad">
	<div class="card-content">
		<h2 class="mb-3 inline-flex items-center gap-2 text-2xl font-semibold md:mb-4">
			<Icon name="school" class="h-5 w-5 text-accent-secondary" aria-hidden="true" />
			Educación
		</h2>
		{education.map((item) => (
			<div class="mb-4 last:mb-0">
				<h3 class="text-lg font-semibold text-tx-main">{item.degree}</h3>
				<p class="mt-1 inline-flex items-center gap-1.5 text-sm text-tx-secondary transition-colors duration-300 hover:text-tx-main">
					<Icon name="map-pin" class="h-3.5 w-3.5" aria-hidden="true" />
					{item.institution} · {item.location}
				</p>
				<p class="mt-1 inline-flex items-center gap-1.5 font-mono text-xs text-tx-secondary">
					<Icon name="calendar" class="h-3.5 w-3.5" aria-hidden="true" />
					{formatPeriod(item.startDate, item.endDate)}
				</p>
			</div>
		))}
	</div>
</section>
