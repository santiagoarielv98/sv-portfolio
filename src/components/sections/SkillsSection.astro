---
interface SkillGroup {
	category: string;
	items: string[];
}

interface Props {
	skills: SkillGroup[];
}

const { skills } = Astro.props as Props;
---

<section>
	<h2 class="mb-4 text-2xl font-semibold md:mb-6">Skills</h2>
	<div class="grid gap-3 sm:gap-4 md:grid-cols-3 md:gap-5">
		{skills.map((group) => (
			<article class="card card-pad">
				<div class="card-content">
					<h3 class="mb-3 text-lg font-semibold text-tx-main md:mb-4">{group.category}</h3>
					<ul class="flex flex-wrap gap-2">
						{group.items.map((item) => (
							<li class="rounded-lg border border-border-subtle bg-bg-hover px-2.5 py-1 font-mono text-xs text-tx-secondary transition-colors duration-300 hover:border-border-strong hover:text-tx-main">{item}</li>
						))}
					</ul>
				</div>
			</article>
		))}
	</div>
</section>
