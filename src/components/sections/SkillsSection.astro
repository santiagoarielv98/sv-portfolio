---
import Card from '../ui/Card.astro';
import CardHeader from '../ui/CardHeader.astro';
import CardTitle from '../ui/CardTitle.astro';
import CardContent from '../ui/CardContent.astro';
import Tag from '../ui/Tag.astro';

interface SkillGroup {
	category: string;
	items: string[];
}

interface Props {
	skills: SkillGroup[];
}

const { skills } = Astro.props as Props;
---

<section>
	<h2 class="mb-4 text-2xl font-semibold md:mb-6">Skills</h2>
	<div class="grid gap-3 sm:gap-4 md:grid-cols-3 md:gap-5">
		{skills.map((group) => (
			<Card as="article">
				<CardHeader class="pb-0">
					<CardTitle class="text-lg md:text-lg">{group.category}</CardTitle>
				</CardHeader>
				<CardContent class="pt-3 md:pt-4">
					<ul class="flex flex-wrap gap-2">
						{group.items.map((item) => (
							<li>
								<Tag interactive>{item}</Tag>
							</li>
						))}
					</ul>
				</CardContent>
			</Card>
		))}
	</div>
</section>
