---
import { Icon } from "astro-icon/components";
import Badge from "../ui/Badge.astro";
import Tag from "../ui/Tag.astro";
import {
  Card,
  CardHeader,
  CardTitle,
  CardDescription,
  CardContent,
} from "../ui/card";

interface SkillGroup {
  category: string;
  items: string[];
}

interface Props {
  skills: SkillGroup[];
}

const { skills } = Astro.props as Props;
---

<section>
  <h2 class="mb-4 text-2xl font-semibold md:mb-6">Skills</h2>
  <div class="grid gap-3 sm:gap-4 md:grid-cols-3 md:gap-5">
    {
      skills.map((group) => (
        <Card>
          <CardHeader className="pb-0">
            <div class="flex items-start justify-between gap-3">
              <div class="border-border-subtle bg-bg-main text-accent-glow shadow-glass flex h-11 w-11 items-center justify-center rounded-lg border">
                <Icon name="folder-code" class="h-5 w-5" aria-hidden="true" />
              </div>
              <Badge variant="outline" size="md">
                {group.items.length} skills
              </Badge>
            </div>
            <CardTitle className="group-hover:text-accent-glow mt-4 text-lg transition-colors duration-300">
              {group.category}
            </CardTitle>
            <CardDescription className="mt-2">
              Tecnologías clave de esta área.
            </CardDescription>
          </CardHeader>
          <CardContent className="pt-3 md:pt-4">
            <ul class="flex flex-wrap gap-2">
              {group.items.map((item) => (
                <li>
                  <Tag interactive>{item}</Tag>
                </li>
              ))}
            </ul>
          </CardContent>
        </Card>
      ))
    }
  </div>
</section>
