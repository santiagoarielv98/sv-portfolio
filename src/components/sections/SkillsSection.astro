---
interface SkillGroup {
	category: string;
	items: string[];
}

interface Props {
	skills: SkillGroup[];
}

const { skills } = Astro.props as Props;
---

<section>
	<h2 class="mb-6 text-2xl font-semibold">Skills</h2>
	<div class="grid gap-5 md:grid-cols-3">
		{skills.map((group) => (
			<article class="surface p-5 transition-all duration-300 ease-out hover:-translate-y-0.5 hover:border-border-strong hover:shadow-glow-primary">
				<h3 class="mb-4 text-lg font-semibold text-tx-main">{group.category}</h3>
				<ul class="flex flex-wrap gap-2">
					{group.items.map((item) => (
						<li class="rounded-lg border border-border-subtle bg-bg-hover px-2.5 py-1 font-mono text-xs text-tx-secondary transition-colors duration-300 hover:border-border-strong hover:text-tx-main">{item}</li>
					))}
				</ul>
			</article>
		))}
	</div>
</section>
