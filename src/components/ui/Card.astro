---
interface Props {
  as?: "div" | "article" | "section";
  class?: string;
}

const { as = "div", class: className = "" } = Astro.props as Props;
const Element = as;
---

<Element
  class:list={[
    "group/card border-border-subtle bg-bg-card shadow-glass hover:border-accent-primary/30 hover:shadow-glow-primary focus-within:border-accent-primary/35 focus-within:shadow-glow-primary relative flex flex-col overflow-hidden rounded-xl border transition-[border-color,box-shadow,opacity] duration-300",
    className,
  ]}
>
  <div
    class="from-accent-primary/5 pointer-events-none absolute inset-0 bg-linear-to-br to-transparent opacity-0 transition-opacity duration-300 group-focus-within/card:opacity-100 group-hover/card:opacity-100"
  >
  </div>
  <slot />
</Element>
