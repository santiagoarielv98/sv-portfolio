---
interface Props {
  interactive?: boolean;
  size?: "sm" | "md";
  class?: string;
}

const {
  interactive = false,
  size = "md",
  class: className = "",
} = Astro.props as Props;

const sizeClass: Record<NonNullable<Props["size"]>, string> = {
  sm: "px-2 py-0.5 text-[10px]",
  md: "px-2.5 py-1 text-xs",
};
---

<span
  class:list={[
    "border-border-subtle bg-bg-hover text-tx-secondary inline-flex items-center rounded-lg border font-mono",
    sizeClass[size],
    interactive
      ? "hover:border-border-strong hover:text-tx-main transition-[color,border-color,opacity] duration-200"
      : "",
    className,
  ]}
>
  <slot />
</span>
