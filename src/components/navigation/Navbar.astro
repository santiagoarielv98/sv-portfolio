---
import { navItems } from "./navItems";
import ThemeToggle from "../ui/ThemeToggle.astro";

interface Props {
  pathname: string;
}

const { pathname } = Astro.props as Props;
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;
const isActive = (id: string) => {
  if (id === "home") return currentPath === "/";
  if (id === "projects") return currentPath.startsWith("/proyectos");
  return false;
};
---

<header class="border-border-subtle bg-bg-main/80 border-b backdrop-blur">
  <nav
    class="mx-auto flex w-full max-w-6xl items-center justify-between px-4 py-3 sm:px-5 md:px-8"
  >
    <a
      href="/"
      class="text-accent-glow hover:text-accent-primary font-mono text-xs transition-colors"
      >sv</a
    >
    <div class="flex items-center gap-2 text-sm">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              "rounded-lg border px-3 py-1.5 transition-colors",
              isActive(item.id)
                ? "border-accent-primary/35 bg-accent-primary/10 text-accent-glow"
                : "border-border-subtle text-tx-secondary hover:border-border-strong hover:text-tx-main",
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <ThemeToggle />
    </div>
  </nav>
</header>
