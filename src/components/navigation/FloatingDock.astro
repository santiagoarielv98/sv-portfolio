---
import { Icon } from "astro-icon/components";
import { navItems } from "./navItems";
import ThemeToggle from "../ui/ThemeToggle.astro";

interface Props {
  pathname: string;
}

const { pathname } = Astro.props as Props;
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;
const isActive = (id: string) => {
  if (id === "home") return currentPath === "/";
  if (id === "projects") return currentPath.startsWith("/proyectos");
  return false;
};
---

<div class="fixed inset-x-0 bottom-4 z-40 flex justify-center">
  <div
    class="border-border-strong bg-bg-card/85 shadow-glass inline-flex items-center gap-1.5 rounded-2xl border p-2 backdrop-blur-xl"
  >
    {
      navItems.map((item) => (
        <div class="group relative">
          <a
            href={item.href}
            class:list={[
              "inline-flex h-10 w-10 items-center justify-center rounded-xl border transition-colors",
              isActive(item.id)
                ? "border-accent-primary/30 bg-accent-primary/10 text-accent-glow"
                : "text-tx-secondary hover:border-border-subtle hover:bg-bg-hover hover:text-tx-main border-transparent",
            ]}
            aria-label={item.label}
          >
            <Icon name={item.icon} class="h-4.5 w-4.5" aria-hidden="true" />
          </a>
          <span class="border-border-subtle bg-bg-card text-tx-secondary shadow-glass pointer-events-none absolute -top-8 right-0 left-0 mx-auto w-max scale-95 rounded-md border px-2 py-1 font-mono text-[10px] whitespace-nowrap opacity-0 transition-[opacity,scale] duration-200 group-focus-within:scale-100 group-focus-within:opacity-100 group-hover:scale-100 group-hover:opacity-100">
            {item.label}
          </span>
        </div>
      ))
    }
    <div class="bg-border-strong mx-1 h-6 w-px"></div>
    <div class="group relative">
      <ThemeToggle
        buttonClass="h-10 w-10 rounded-xl border-transparent bg-transparent hover:border-border-subtle"
      />
      <span
        class="border-border-subtle bg-bg-card text-tx-secondary shadow-glass pointer-events-none absolute -top-8 right-0 left-0 mx-auto w-max scale-95 rounded-md border px-2 py-1 font-mono text-[10px] whitespace-nowrap opacity-0 transition-[opacity,scale] duration-200 group-focus-within:scale-100 group-focus-within:opacity-100 group-hover:scale-100 group-hover:opacity-100"
      >
        Tema
      </span>
    </div>
  </div>
</div>
