---
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import '../../styles/global.css';

const projectEntries = await getCollection('projects');
const toSlug = (id: string) => id.replace(/\.md$/, '');

const projects = projectEntries
	.map((entry) => ({
		slug: toSlug(entry.id),
		title: entry.data.title,
		description: entry.data.description,
		techStack: entry.data.techStack,
		status: entry.data.status,
		year: entry.data.year,
		github: entry.data.github,
		link: `/proyectos/${toSlug(entry.id)}`,
	}))
	.sort((a, b) => Number(b.year) - Number(a.year));

const allTechnologies = [...new Set(projects.flatMap((project) => project.techStack))].sort();
const allStatuses = [...new Set(projects.map((project) => project.status))];
---

<Layout
	title="Proyectos | Santiago Ariel Villanueva"
	description="Listado de proyectos y productos construidos por Santiago Ariel Villanueva."
>
	<main class="mx-auto flex w-full max-w-6xl flex-col gap-8 px-4 py-8 sm:gap-10 sm:px-5 sm:py-10 md:gap-12 md:px-8 md:py-14">
		<header class="border-b border-border-subtle pb-8 md:pb-10">
			<p class="mb-3 inline-flex items-center gap-2 font-mono text-xs text-accent-glow">
				<Icon name="folder-open" class="h-4 w-4" aria-hidden="true" />
				Catálogo de proyectos
			</p>
			<h1 class="mb-3 text-3xl font-bold leading-tight sm:text-4xl md:text-5xl">Proyectos</h1>
			<p class="max-w-3xl text-sm leading-relaxed text-tx-secondary md:text-base">
				Una vista completa de productos y librerías con enfoque en performance, arquitectura y experiencia de usuario.
			</p>
		</header>

		<section class="rounded-xl border border-border-subtle bg-bg-card p-4 shadow-glass sm:p-5 md:p-6">
			<div class="mb-4 grid gap-3 md:grid-cols-[1fr_auto] md:items-end">
				<label class="flex flex-col gap-1.5">
					<span class="inline-flex items-center gap-1.5 text-xs font-mono text-tx-secondary">
						<Icon name="search" class="h-3.5 w-3.5" aria-hidden="true" />
						Buscar proyecto
					</span>
					<input
						id="project-search"
						type="search"
						placeholder="Buscar por título, descripción o tecnología..."
						class="h-10 rounded-lg border border-border-subtle bg-bg-main px-3 text-sm text-tx-main outline-none transition-colors placeholder:text-tx-muted focus:border-accent-primary/50"
					/>
				</label>
				<button
					id="filters-reset"
					type="button"
					class="inline-flex h-10 items-center justify-center rounded-lg border border-border-subtle px-3 text-sm text-tx-secondary transition-colors hover:border-border-strong hover:text-tx-main"
				>
					<Icon name="filter" class="mr-1 h-3.5 w-3.5" aria-hidden="true" />
					Limpiar filtros
				</button>
			</div>

			<div class="mb-3">
				<p class="mb-2 inline-flex items-center gap-1.5 text-xs font-mono text-tx-secondary">
					<Icon name="cpu" class="h-3.5 w-3.5" aria-hidden="true" />
					Filtrar por tecnología
				</p>
				<div class="flex flex-wrap gap-2">
					{allTechnologies.map((tech) => (
						<label class="tech-chip inline-flex cursor-pointer items-center gap-2 rounded-lg border border-border-subtle bg-bg-main px-2.5 py-1.5 text-xs text-tx-secondary transition-colors hover:border-border-strong hover:text-tx-main">
							<input class="tech-filter sr-only" type="checkbox" value={tech} />
							<span>{tech}</span>
						</label>
					))}
				</div>
			</div>

			<div>
				<p class="mb-2 inline-flex items-center gap-1.5 text-xs font-mono text-tx-secondary">
					<Icon name="circle-check" class="h-3.5 w-3.5" aria-hidden="true" />
					Estado
				</p>
				<div class="flex flex-wrap gap-2">
					<button type="button" data-status="all" class="status-filter rounded-lg border border-accent-primary/35 bg-accent-primary/10 px-2.5 py-1.5 text-xs text-accent-glow">Todos</button>
					{allStatuses.map((status) => (
						<button type="button" data-status={status} class="status-filter rounded-lg border border-border-subtle bg-bg-main px-2.5 py-1.5 text-xs text-tx-secondary transition-colors hover:border-border-strong hover:text-tx-main">{status}</button>
					))}
				</div>
			</div>
		</section>

		<section id="projects-grid" class="grid gap-3 sm:gap-4 md:grid-cols-2 md:gap-5 xl:grid-cols-3">
			{projects.map((project) => (
				<div
					class="project-item"
					data-title={project.title.toLowerCase()}
					data-description={project.description.toLowerCase()}
					data-status={project.status}
					data-tech={project.techStack.join('|').toLowerCase()}
				>
					<ProjectCard {...project} />
				</div>
			))}
		</section>

		<p id="projects-empty" class="hidden rounded-lg border border-border-subtle bg-bg-card px-4 py-3 text-sm text-tx-secondary">
			No hay proyectos que coincidan con esos filtros.
		</p>
	</main>

	<script>
		const searchInput = document.getElementById('project-search') as HTMLInputElement | null;
		const resetButton = document.getElementById('filters-reset') as HTMLButtonElement | null;
		const techInputs = Array.from(document.querySelectorAll('.tech-filter') ) as HTMLInputElement[];
		const statusButtons = Array.from(document.querySelectorAll('.status-filter')) as HTMLButtonElement[];
		const projectItems = Array.from(document.querySelectorAll('.project-item')) as HTMLDivElement[];
		const emptyState = document.getElementById('projects-empty');

		let selectedStatus = 'all';

		const params = new URLSearchParams(window.location.search);
		const initialQuery = params.get('q') ?? '';
		const initialStatus = params.get('status') ?? 'all';
		const initialTech = (params.get('tech') ?? '').split(',').filter(Boolean);

		if (searchInput) searchInput.value = initialQuery;
		selectedStatus = initialStatus;

		techInputs.forEach((input) => {
			if (initialTech.includes(input.value)) {
				input.checked = true;
			}
		});

		const syncStatusButtons = () => {
			statusButtons.forEach((button) => {
				const isActive = button.dataset.status === selectedStatus;
				button.classList.toggle('border-accent-primary/35', isActive);
				button.classList.toggle('bg-accent-primary/10', isActive);
				button.classList.toggle('text-accent-glow', isActive);
				button.classList.toggle('border-border-subtle', !isActive);
				button.classList.toggle('bg-bg-main', !isActive);
				button.classList.toggle('text-tx-secondary', !isActive);
			});
		};

		const syncTechChips = () => {
			techInputs.forEach((input) => {
				const chip = input.closest('.tech-chip');
				if (!chip) return;

				chip.classList.toggle('border-accent-primary/35', input.checked);
				chip.classList.toggle('bg-accent-primary/10', input.checked);
				chip.classList.toggle('text-accent-glow', input.checked);
				chip.classList.toggle('border-border-subtle', !input.checked);
				chip.classList.toggle('bg-bg-main', !input.checked);
				chip.classList.toggle('text-tx-secondary', !input.checked);
			});
		};

		const updateUrl = (query: string, tech: string[], status: string) => {
			const next = new URLSearchParams();
			if (query) next.set('q', query);
			if (tech.length) next.set('tech', tech.join(','));
			if (status !== 'all') next.set('status', status);
			const nextUrl = `${window.location.pathname}${next.toString() ? `?${next.toString()}` : ''}`;
			window.history.replaceState({}, '', nextUrl);
		};

		const applyFilters = () => {
			const query = (searchInput?.value ?? '').trim().toLowerCase();
			const selectedTech = techInputs.filter((input) => input.checked).map((input) => input.value.toLowerCase());

			let visibleCount = 0;
			projectItems.forEach((item) => {
				const title = item.dataset.title ?? '';
				const description = item.dataset.description ?? '';
				const tech = item.dataset.tech ?? '';
				const status = item.dataset.status ?? '';

				const queryOk = !query || title.includes(query) || description.includes(query) || tech.includes(query);
				const statusOk = selectedStatus === 'all' || status === selectedStatus;
				const techOk = selectedTech.length === 0 || selectedTech.every((value) => tech.includes(value));

				const show = queryOk && statusOk && techOk;
				item.classList.toggle('hidden', !show);
				if (show) visibleCount += 1;
			});

			emptyState?.classList.toggle('hidden', visibleCount > 0);
			updateUrl(query, selectedTech, selectedStatus);
		};

		searchInput?.addEventListener('input', applyFilters);
		techInputs.forEach((input) => {
			input.addEventListener('change', () => {
				syncTechChips();
				applyFilters();
			});
		});
		statusButtons.forEach((button) => {
			button.addEventListener('click', () => {
				selectedStatus = button.dataset.status ?? 'all';
				syncStatusButtons();
				applyFilters();
			});
		});

		resetButton?.addEventListener('click', () => {
			if (searchInput) searchInput.value = '';
			techInputs.forEach((input) => {
				input.checked = false;
			});
			selectedStatus = 'all';
			syncTechChips();
			syncStatusButtons();
			applyFilters();
		});

		syncTechChips();
		syncStatusButtons();
		applyFilters();
	</script>
</Layout>
